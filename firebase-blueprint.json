{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about registered users (Mahasiswa or Panitia)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The firebase auth user ID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Academic or structural email" },
        "organization": { "type": "string", "description": "University organization or student group name" },
        "plan": { "type": "string", "enum": ["free", "basic", "pro"], "description": "SaaS plan status" },
        "registeredAt": { "type": "string", "description": "ISO 8601 registration timestamp" },
        "role": { "type": "string", "enum": ["mahasiswa", "panitia"], "description": "Role of the user in the portal" }
      },
      "required": ["id", "name", "email", "organization", "plan", "registeredAt", "role"]
    },
    "Event": {
      "title": "Event Information",
      "description": "Details of university events, seminars, or workshops created by organizers",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique Event ID" },
        "userId": { "type": "string", "description": "Id of the creator of the event" },
        "title": { "type": "string", "description": "Title of the event" },
        "description": { "type": "string", "description": "Brief description of event contents" },
        "date": { "type": "string", "description": "Event Date format YYYY-MM-DD" },
        "time": { "type": "string", "description": "Event Time format HH:MM" },
        "location": { "type": "string", "description": "Event Venue / Hall room or online link" },
        "type": { "type": "string", "enum": ["Seminar", "Workshop", "Lomba", "Rapat", "Makrab", "Pelatihan", "Komunitas", "Sosialisasi"], "description": "Category of the event" },
        "capacity": { "type": "number", "description": "Max attendees allowed" },
        "ticketPrice": { "type": "number", "description": "Cost of a single ticket" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Ended"], "description": "Life cycle status of the event" }
      },
      "required": ["id", "userId", "title", "description", "date", "time", "location", "type", "capacity", "ticketPrice", "status"]
    },
    "Participant": {
      "title": "Event Participant",
      "description": "Details of students registered to attend a specific event",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique registration ID" },
        "eventId": { "type": "string", "description": "ID of the target event" },
        "name": { "type": "string", "description": "Full name of the registrant" },
        "email": { "type": "string", "format": "email", "description": "Email of the registrant" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "ticketCode": { "type": "string", "description": "Custom TK-XXXX format for easy QR scan check-in" },
        "status": { "type": "string", "enum": ["Registered", "Attended"], "description": "Attendance status" },
        "registeredAt": { "type": "string", "description": "ISO timestamp for registration time" },
        "attendedAt": { "type": "string", "description": "ISO timestamp for scanner check-in" }
      },
      "required": ["id", "eventId", "name", "email", "phone", "ticketCode", "status", "registeredAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Lookup path for single user records mapped by their Firebase Auth UID."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Storage for events created by organizers."
    },
    "/participants/{participantId}": {
      "schema": "Participant",
      "description": "Registrations made by students for their respective events globally."
    }
  }
}
